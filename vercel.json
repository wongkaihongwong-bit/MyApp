{
  "version": 2,
  "name": "ai-studio-companion-portal",
  "description": "Exposes an operational web deployment portal and dynamic telemetry dashboard synced to the companion app, logs, and database schema.",
  "cleanUrls": true,
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        {
          "key": "Access-Control-Allow-Origin",
          "value": "*"
        },
        {
          "key": "X-Frame-Options",
          "value": "DENY"
        }
      ]
    }
  ],
  "routes": [
    {
      "src": "/api/v1/telemetry",
      "dest": "/api/telemetry.js"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ]
}
